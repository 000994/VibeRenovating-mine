DATABASE_URL=sqlite:///./viberenovating.db
OUTPUT_DIR=./output

SF3D_API_KEY=your_sf3d_api_key_here
MESHY_API_KEY=your_meshy_api_key_here
RODIN_API_KEY=your_rodin_api_key_here
HUNYUAN_API_KEY=your_hunyuan_secret_id_here
HUNYUAN_SECRET_KEY=your_hunyuan_secret_key_here
TRIPO_API_KEY=your_tripo_api_key_here

# Prompt router LLM (DashScope compatible-mode by default)
PROMPT_ROUTER_API_KEY=your_dashscope_api_key_here
PROMPT_ROUTER_MODEL=qwen2.5-7b-instruct
PROMPT_ROUTER_VISION_MODEL=qwen2.5-vl-7b-instruct
PROMPT_ROUTER_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
